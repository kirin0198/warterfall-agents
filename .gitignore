# Aphelion repo's own dev-time local overrides (the file is shipped as a deny-list
# template via src/.claude/settings.local.json, see #31). Anchor with leading slash so
# only the root copy is ignored; the negation un-ignores the canonical template at
# src/.claude/ even when a user's global gitignore has `**/.claude/settings.local.json`.
/.claude/settings.local.json
!src/.claude/settings.local.json

# Dogfooding: this repo's own hook registration is a shared asset (PR 1c/4, #107).
# settings.json (not settings.local.json) must remain committed.
# Explicit negation protects against user-level gitignore patterns like `**/.claude/settings.json`.
!/.claude/settings.json

# Node
node_modules/

# Local dev artifacts (claude CLI generates this during worktree-based sessions)
/.claude/worktrees/
